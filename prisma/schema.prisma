// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Sex {
  MALE
  FEMALE
  OTHER
}

enum ClinicRole {
  OWNER
  ADMIN
  MEMBER
}

enum ToothStatus {
  HEALTHY
  CARIES
  MISSING
  CROWN
  FILLING
  IMPACTED
  ROOT_CANAL
  BRIDGE
  IMPLANT
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                String         @id @default(cuid())
  name              String?
  email             String?        @unique
  emailVerified     DateTime?
  image             String?
  sessions          Session[]
  patients          UserPatient[]
  appointments      Appointment[]
  clinicMemberships ClinicMember[]
  activeClinicId    String?
  activeClinic      Clinic?        @relation(fields: [activeClinicId], references: [id])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Patient {
  id           String         @id @default(cuid())
  name         String
  birthDate    DateTime
  sex          Sex            @default(OTHER)
  phone        String         @unique
  email        String         @unique
  clinic       Clinic         @relation(fields: [clinicId], references: [id])
  clinicId     String
  doctors      UserPatient[]
  appointments Appointment[]
  teeth        PatientTooth[]
}

model UserPatient {
  user      User?    @relation(fields: [userId], references: [id])
  userId    String
  patient   Patient? @relation(fields: [patientId], references: [id])
  patientId String

  @@unique([userId, patientId])
}

model Operation {
  id              String                      @id @default(cuid())
  name            String                      @unique
  toothOperations AppointmentToothOperation[]
  clinicPrices    ClinicOperationPrice[]
}

model Appointment {
  id              String                      @id @default(cuid())
  title           String
  start           DateTime
  end             DateTime
  patient         Patient?                    @relation(fields: [patientId], references: [id])
  patientId       String
  clinic          Clinic                      @relation(fields: [clinicId], references: [id])
  clinicId        String
  user            User?                       @relation(fields: [userId], references: [id])
  userId          String
  toothOperations AppointmentToothOperation[]
}

model Clinic {
  id              String                 @id @default(cuid())
  name            String
  createdAt       DateTime               @default(now())
  members         ClinicMember[]
  patients        Patient[]
  appointments    Appointment[]
  operationPrices ClinicOperationPrice[]
  activeUsers     User[]
}

model ClinicOperationPrice {
  id          String    @id @default(cuid())
  clinic      Clinic    @relation(fields: [clinicId], references: [id])
  clinicId    String
  operation   Operation @relation(fields: [operationId], references: [id])
  operationId String
  price       Int

  @@unique([clinicId, operationId])
}

model ClinicMember {
  id        String     @id @default(cuid())
  clinic    Clinic     @relation(fields: [clinicId], references: [id])
  clinicId  String
  user      User?      @relation(fields: [userId], references: [id])
  userId    String?
  email     String?
  role      ClinicRole @default(MEMBER)
  color     String     @default("#5d8da8")
  createdAt DateTime   @default(now())

  @@unique([clinicId, userId])
  @@unique([clinicId, email])
}

model Tooth {
  code            String                      @id
  toothOperations AppointmentToothOperation[]
  patientTeeth    PatientTooth[]
}

model PatientTooth {
  patient    Patient                     @relation(fields: [patientId], references: [id])
  patientId  String
  tooth      Tooth                       @relation(fields: [toothCode], references: [code])
  toothCode  String
  status     ToothStatus                 @default(HEALTHY)
  operations AppointmentToothOperation[]

  @@id([patientId, toothCode])
}

model AppointmentToothOperation {
  appointment   Appointment  @relation(fields: [appointmentId], references: [id])
  appointmentId String
  tooth         Tooth        @relation(fields: [toothCode], references: [code])
  toothCode     String
  patientTooth  PatientTooth @relation(fields: [patientId, toothCode], references: [patientId, toothCode])
  patientId     String
  operation     Operation    @relation(fields: [operationId], references: [id])
  operationId   String

  @@id([appointmentId, toothCode, operationId])
}
