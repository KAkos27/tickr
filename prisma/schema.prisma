// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Sex {
  MALE
  FEMALE
  OTHER
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  sessions      Session[]
  patients      UserPatient[]
  appointments  Appointment[]
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Patient {
  id           String         @id @default(cuid())
  name         String
  birthDate    DateTime
  sex          Sex            @default(OTHER)
  phone        String         @unique
  email        String         @unique
  doctors      UserPatient[]
  appointments Appointment[]
  teeth        PatientTooth[]
}

model UserPatient {
  user      User?    @relation(fields: [userId], references: [id])
  userId    String
  patient   Patient? @relation(fields: [patientId], references: [id])
  patientId String

  @@unique([userId, patientId])
}

model Operation {
  id              String                      @id @default(cuid())
  name            String                      @unique
  price           Int
  toothOperations AppointmentToothOperation[]
}

model Appointment {
  id              String                      @id @default(cuid())
  title           String
  start           DateTime
  end             DateTime
  patient         Patient?                    @relation(fields: [patientId], references: [id])
  patientId       String
  user            User?                       @relation(fields: [userId], references: [id])
  userId          String
  toothOperations AppointmentToothOperation[]
}

model Tooth {
  code            String                      @id
  toothOperations AppointmentToothOperation[]
  patientTeeth    PatientTooth[]
}

model PatientTooth {
  patient    Patient                     @relation(fields: [patientId], references: [id])
  patientId  String
  tooth      Tooth                       @relation(fields: [toothCode], references: [code])
  toothCode  String
  operations AppointmentToothOperation[]

  @@id([patientId, toothCode])
}

model AppointmentToothOperation {
  appointment   Appointment  @relation(fields: [appointmentId], references: [id])
  appointmentId String
  tooth         Tooth        @relation(fields: [toothCode], references: [code])
  toothCode     String
  patientTooth  PatientTooth @relation(fields: [patientId, toothCode], references: [patientId, toothCode])
  patientId     String
  operation     Operation    @relation(fields: [operationId], references: [id])
  operationId   String

  @@id([appointmentId, toothCode, operationId])
}
